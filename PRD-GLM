Berikut adalah script SQL lengkap untuk MySQL. Skema ini sudah memperhitungkan Relational Integrity​, Auto-decrement stok via Triggers​, dan Multi-user​.

2.1. Pembuatan Database & Tabel

sql

-- Buat Database
CREATE DATABASE IF NOT EXISTS glm_pos;
USE glm_pos;
-- 1. Tabel Users (Multi-User & RBAC)
CREATE TABLE users (
id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(100) NOT NULL,
email VARCHAR(100) UNIQUE NOT NULL,
password_hash VARCHAR(255) NOT NULL,
role ENUM('ADMIN', 'MANAGER', 'CASHIER', 'WAITER', 'KITCHEN') NOT NULL DEFAULT 'WAITER',
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);
-- 2. Tabel Categories
CREATE TABLE categories (
id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(50) NOT NULL,
description TEXT,
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
-- 3. Tabel Products (Menu/Apuran Jadi)
CREATE TABLE products (
id INT AUTO_INCREMENT PRIMARY KEY,
category_id INT,
name VARCHAR(100) NOT NULL,
description TEXT,
price DECIMAL(10, 2) NOT NULL,
image_url VARCHAR(255),
is_available BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
FOREIGN KEY (category_id) REFERENCES categories(id) ON DELETE SET NULL
);
-- 4. Tabel Raw Materials (Bahan Baku)
CREATE TABLE raw_materials (
id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(100) NOT NULL,
unit VARCHAR(20) NOT NULL, -- Contoh: 'ml', 'gr', 'pcs'
stock DECIMAL(10, 2) DEFAULT 0.00,
min_stock DECIMAL(10, 2) DEFAULT 0.00, -- Alert stok menipis
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
-- 5. Tabel Recipes (Resep / Bill of Materials)
-- Menghubungkan Product dengan Raw Material
CREATE TABLE recipes (
id INT AUTO_INCREMENT PRIMARY KEY,
product_id INT NOT NULL,
raw_material_id INT NOT NULL,
quantity_used DECIMAL(10, 2) NOT NULL, -- Jumlah bahan baku yg dipakai per 1 porsi menu
FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE CASCADE,
FOREIGN KEY (raw_material_id) REFERENCES raw_material(id) ON DELETE RESTRICT
);
-- 6. Tabel Transactions (Kepala Transaksi/Order)
CREATE TABLE transactions (
id INT AUTO_INCREMENT PRIMARY KEY,
invoice_number VARCHAR(50) UNIQUE NOT NULL,
cashier_id INT NOT NULL, -- User yang melakukan transaksi
waiter_id INT NULL, -- User waiter (opsional, jika pesanan dari waiter)
table_number VARCHAR(20),
status ENUM('PENDING', 'PAID', 'CANCELLED') NOT NULL DEFAULT 'PAID',
subtotal DECIMAL(10, 2) NOT NULL DEFAULT 0.00,
discount DECIMAL(10, 2) DEFAULT 0.00,
tax DECIMAL(10, 2) DEFAULT 0.00,
service_charge DECIMAL(10, 2) DEFAULT 0.00,
total_amount DECIMAL(10, 2) NOT NULL DEFAULT 0.00,
payment_method ENUM('CASH', 'QRIS', 'DEBIT', 'CREDIT') DEFAULT 'CASH',
notes TEXT,
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
FOREIGN KEY (cashier_id) REFERENCES users(id) ON DELETE RESTRICT,
FOREIGN KEY (waiter_id) REFERENCES users(id) ON DELETE SET NULL
);
-- 7. Tabel Transaction Details (Item Transaksi/Item Pesanan)
CREATE TABLE transaction_details (
id INT AUTO_INCREMENT PRIMARY KEY,
transaction_id INT NOT NULL,
product_id INT NOT NULL,
quantity INT NOT NULL DEFAULT 1,
price_at_sale DECIMAL(10, 2) NOT NULL, -- Harga menu saat itu (jika harga berubah di masa depan, data transaksi lalu tidak rusak)
notes VARCHAR(255), -- Contoh: "Tanpa Es", "Level Pedas 5"
FOREIGN KEY (transaction_id) REFERENCES transactions(id) ON DELETE CASCADE,
FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE RESTRICT
);
-- 8. Tabel Stock Movements (Riwayat keluar masuk stok)
CREATE TABLE stock_movements (
id INT AUTO_INCREMENT PRIMARY KEY,
raw_material_id INT NOT NULL,
type ENUM('IN', 'OUT', 'ADJUSTMENT') NOT NULL,
quantity DECIMAL(10, 2) NOT NULL,
description VARCHAR(255), -- Contoh: 'Supplier order', 'Wastage/Sample', 'Auto deduct from sale ID X'
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
FOREIGN KEY (raw_material_id) REFERENCES raw_material(id) ON DELETE RESTRICT
);
2.2. Trigger SQL ( Otomatis Kurangi Stok saat Transaksi )

Agar aplikasi Next.js tidak perlu melakukan logika pengurangan stok secara manual (menghindari race-condition saat banyak kasir_transaksi bersamaan), kita gunakan MySQL Trigger​.

sql

DELIMITER //
CREATE TRIGGER trg_after_transaction_detail_insert
AFTER INSERT ON transaction_details
FOR EACH ROW
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE r_mat_id INT;
DECLARE r_qty DECIMAL(10,2);

    -- Cursor untuk mencari bahan baku dari recipe product yang baru dijual
    DECLARE recipe_cur CURSOR FOR
        SELECT raw_material_id, quantity_used
        FROM recipes
        WHERE product_id = NEW.product_id;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN recipe_cur;

    read_loop: LOOP
        FETCH recipe_cur INTO r_mat_id, r_qty;
        IF done THEN
            LEAVE read_loop;
        END IF;

        -- Hitung total bahan yang dipakai = qty item * qty resep
        SET @total_used = NEW.quantity * r_qty;

        -- Update stok material (Kurangi)
        UPDATE raw_materials
        SET stock = stock - @total_used
        WHERE id = r_mat_id;

        -- Catat pergerakan stok di stock_movements
        INSERT INTO stock_movements (raw_material_id, type, quantity, description)
        VALUES (r_mat_id, 'OUT', @total_used, CONCAT('Auto deduct: Sale Transaction #', NEW.transaction_id));

    END LOOP;

    CLOSE recipe_cur;

END //
DELIMITER ;
